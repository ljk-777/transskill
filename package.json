{
  "name": "transskill",
  "version": "0.4.2",
  "description": "Cross-platform AI agent skill converter - Write once, run on any agent",
  "bin": {
    "transskill": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist/"
  ],
  "keywords": [
    "ai-agent",
    "skill",
    "converter",
    "claude-code",
    "cursor",
    "openclaw",
    "mcp"
  ],
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@clack/prompts": "^1.4.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "execa": "^9.5.2",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "tempy": "^3.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "eslint": "^9.24.0",
    "prettier": "^3.5.3",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
