{
  "name": "weather-server",
  "description": "Weather forecast MCP server",
  "tools": [
    {
      "name": "get_forecast",
      "description": "Get weather forecast for a location",
      "inputSchema": {
        "type": "object",
        "properties": {
          "location": { "type": "string", "description": "City name or coordinates" },
          "days": { "type": "number", "description": "Number of forecast days" }
